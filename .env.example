# Copy to .env and fill in. Used by docker-compose.

# Address Greenlight listens on. Change the port here (e.g. :9000). Defaults to
# :8080. In Docker, update the compose port mapping to match.
GREENLIGHT_ADDR=:8080

# Public URL of the Greenlight UI (used in notification deep links). Set this to
# the public hostname your tunnel/proxy maps to the greenlight container.
GREENLIGHT_PUBLIC_URL=https://greenlight.example.com

# Admin login password for the web UI (single user). Choose something strong.
GREENLIGHT_ADMIN_PASSWORD=change-me-please

# Secret used to sign session + CSRF cookies. Generate with:
#   openssl rand -hex 32
GREENLIGHT_SESSION_SECRET=change-me-to-64-hex-chars

# Global fallback default action + timeout when no rule / per-request value applies.
GREENLIGHT_DEFAULT_ACTION=reject
GREENLIGHT_DEFAULT_TIMEOUT_SECONDS=3600

# Auto-delete decided requests older than this (Go duration, e.g. 168h = 7 days).
# Pending requests are never deleted. Leave blank / unset to keep history forever.
GREENLIGHT_HISTORY_RETENTION=168h

# HTTP method used to call the n8n Wait-node resume URL. It MUST match the Wait
# node's webhook method or n8n returns 404. n8n's default is GET; the bundled
# reference workflow uses POST. The decision is always also appended as query
# params, so a GET Wait node can read it from $json.query.
GREENLIGHT_RESUME_METHOD=POST

# --- ntfy (your own server) ---
# Base URL of your existing ntfy server. Leave blank to disable notifications.
GREENLIGHT_NTFY_BASE_URL=https://ntfy.example.com
# Topic Greenlight publishes to. Treat it like a secret on a public server.
GREENLIGHT_NTFY_TOPIC=greenlight-approvals
# Access token for that topic (create with `ntfy token add <user>`). Leave blank
# if your ntfy server allows anonymous publish (not recommended).
GREENLIGHT_NTFY_TOKEN=

# Timezone for timestamps shown in the UI.
TZ=UTC
